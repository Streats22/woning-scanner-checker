# API (Laravel): bij lege waarden gebruikt de frontend hetzelfde domein als de browser (/api/...).
# Productie (Nuxt + Laravel op https://dehuurradar.nl): laat beide weg of zet expliciet:
#   NUXT_PUBLIC_API_BASE=https://dehuurradar.nl
#   NUXT_PUBLIC_SITE_URL=https://dehuurradar.nl
#
# Lokaal (Valet): exact hetzelfde schema als in de browser:
#   NUXT_LARAVEL_URL=http://jouw-valet-domein.test
# of:
#   NUXT_PUBLIC_API_BASE=http://jouw-valet-domein.test
#
# php artisan serve (:8000):
#   NUXT_LARAVEL_URL=http://127.0.0.1:8000
#
# Zet NUXT_PUBLIC_API_BASE niet expres op een lege regel (alleen "NUXT_PUBLIC_API_BASE=") — dat overschrijft per ongeluk.
